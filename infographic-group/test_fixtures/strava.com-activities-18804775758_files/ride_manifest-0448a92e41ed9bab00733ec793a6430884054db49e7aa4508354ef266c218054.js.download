(function() {
  Strava.module('Strava.Labs.Activities');

  Strava.Labs.Activities.SharedRideViewFactoryModule = {
    createCriticalPowerView: function(streamsRequest) {
      var $target, chartView, data, lastEndIndex, lastStartIndex, mapCanvas, stateClicked, template, view;
      streamsRequest.require(this.page().chartContext().criticalPowerStreamTypes());
      template = JST['activities/power/curve'];
      data = {
        upsell: this.page().pageContext().isUpsell('power_curve'),
        upsellWithPowerRideCurve: this.page().pageContext().isUpsell('with_power_ride_curve'),
        upsellWeightSet: this.page().pageContext().isUpsell('weight_set'),
        isOwner: this.page().isOwner(),
        activityStartDateLocal: this.page().activity().get('startDateLocal')
      };
      $target = this.$$('#view');
      $target.html(template(data));
      if (!this.page().pageContext().isUpsell('power_curve')) {
        view = new Strava.Activities.PowerPanel.CriticalPowerView({
          el: '#power-panel-cpcurve',
          currentAthleteId: this.page().currentAthlete().id,
          activityPowerModel: this.page().powerController(),
          aggregatePowerModel: new Strava.Athletes.AggregatePowerData(this.page().activityAthlete().id),
          customRangeTemplate: 'activities/power/curve_custom_range',
          infoboxTemplate: 'activities/power/curve_infobox',
          dateFormat: this.page().power()['date_format'],
          chartOptions: {
            w: 850
          }
        });
        lastStartIndex = null;
        lastEndIndex = null;
        stateClicked = false;
        view.cpPowerChart.bind('clickstatechange', (function(_this) {
          return function(data) {
            var d, endIndex, ref, startIndex;
            d = view.cpPowerChart.xToData(data.x);
            if (!(d && d.indexData)) {
              return;
            }
            ref = _this.page().chartContext().convertStreamIndices([d.indexData.startId, d.indexData.endId]), startIndex = ref[0], endIndex = ref[1];
            if (data.state) {
              lastStartIndex = startIndex;
              lastEndIndex = endIndex;
              _this.page().eventDispatcher().dispatchSelect(null, 'latlng', startIndex, endIndex);
              _this.page().router().changeMenuTo("power-curve/" + (view.cpPowerChart.id2time(d.id)), false);
              return stateClicked = true;
            } else {
              _this.page().eventDispatcher().dispatchUnselect(null, 'latlng', lastStartIndex, lastEndIndex);
              lastStartIndex = null;
              lastEndIndex = null;
              _this.page().router().changeMenuTo("power-curve", false);
              return stateClicked = false;
            }
          };
        })(this));
        view.cpPowerChart.bind('mouseaction', (function(_this) {
          return function(data) {
            var d, endIndex, ref, startIndex;
            d = view.cpPowerChart.xToData(data.x);
            if (!(d && d.indexData)) {
              return;
            }
            ref = _this.page().chartContext().convertStreamIndices([d.indexData.startId, d.indexData.endId]), startIndex = ref[0], endIndex = ref[1];
            if (!stateClicked) {
              return _this.page().eventDispatcher().dispatchHover(null, 'latlng', startIndex, endIndex);
            }
          };
        })(this));
        view.cpPowerChart.bind('mouseoutaction', (function(_this) {
          return function(data) {
            return _this.page().eventDispatcher().dispatchHoverOut(null, 'latlng', null, null);
          };
        })(this));
        view.on('viewAnalysis', (function(_this) {
          return function(event) {
            var currentTarget, end, start;
            currentTarget = _this.$$(event.currentTarget);
            start = currentTarget.data('start-id');
            end = currentTarget.data('end-id');
            _this.page().router().changeMenuTo("analysis/" + start + "/" + end, true);
            return event.preventDefault();
          };
        })(this));
      }
      this.addPowerHeaderView($target);
      this.addLogging($target, 'join_summit_power_curve');
      if (this.page().showMap() && this.page().activityAthlete().get('premium')) {
        chartView = new this._segmentsViewFactory(this.page().chartContext(), streamsRequest, false);
        chartView.setElement($target.find('#chart-container')).render();
        mapCanvas = $target.find('#map-canvas');
        if (this.page().hasStreams() && mapCanvas.length > 0) {
          this.page().renderActivityDetailsMREMap({
            mapCanvas: mapCanvas,
            mapProps: {
              activityId: this.page().activity().id,
              measurementUnits: this.page().measurementUnits(),
              showGpxDownload: false,
              showCreateRoute: false,
              staticMapUrl: this.page().staticMapUrl(),
              isSubscriber: this.page().isPremium(),
              analyticsCategory: 'power_curve',
              node: mapCanvas[0]
            }
          });
        }
      } else {
        $target.find('#map-canvas').hide();
        $target.find('#chart-container').hide();
      }
      return view;
    },
    createBestEffortsView: function() {
      var $node, $target, beesAdpMfeUrl;
      beesAdpMfeUrl = this.page().activity().get('beesAdpMfeUrl');
      $target = this.$$('#view');
      $target.html(JST['activities/best_efforts/bees_view']());
      $node = this.$$('#best-efforts-adp');
      Strava.ReactComponentMounter.mountComponent({
        node: $node[0],
        component: 'Microfrontend',
        props: {
          url: beesAdpMfeUrl,
          name: 'strava_bees_adp',
          scope: 'strava_bees_adp',
          component: './App',
          appContext: {
            currentAthleteId: this.page().currentAthlete().id,
            activityAthleteId: this.page().activity().get('activityAthleteId'),
            measurementUnits: this.page().measurementUnits(),
