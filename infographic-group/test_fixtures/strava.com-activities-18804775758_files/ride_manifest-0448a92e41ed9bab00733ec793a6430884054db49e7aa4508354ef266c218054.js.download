      if (this.page().hasStreams()) {
        streamsRequest.require(this.page().chartContext().overviewStreamTypes());
      }
      trainer = this.page().activity().get('trainer');
      hasCadenceOrTemp = this.page().activity().hasCadenceOrTemp();
      showStats = this.page().activity().showStats();
      hasStreams = this.page().hasStreams();
      locals = {
        hasStreams: hasStreams,
        showMapSection: hasStreams && !trainer,
        showChart: hasStreams && (!trainer || hasCadenceOrTemp || showStats.pace || showStats.heartrate)
      };
