(function() {
  Strava.module('Strava.Ui.Global');

  Strava.Ui.Global = (function() {
    function Global() {}

    Global.prepareAutoresizingTextbox = function() {
      return jQuery(document).on('focus', 'textarea.autoresize', function() {
        var input;
        input = jQuery(this);
        if (!input.siblings('div.textarea-clone').length) {
          return input.addClass('noresize').after("<div class='textarea-clone'></div>").bind('keydown paste', function(event) {
            return setTimeout((function(_this) {
              return function() {
                var clone, newHeight, textareaContent;
                clone = input.next();
                textareaContent = input.val() + 'W';
                clone.text(textareaContent);
                newHeight = clone.outerHeight();
                return input.css('height', newHeight);
              };
            })(this), 10);
          });
        }
      });
    };

    return Global;

  })();

}).call(this);
(function() {
  Strava.module('Strava.Labs.Activities.SimilarActivities');

  Strava.Labs.Activities.SimilarActivities.ChartDataContext = (function() {
    function ChartDataContext(similarActivities, dimensionContext) {
      this.similarActivities = similarActivities;
      this.dimensionContext = dimensionContext;
    }

    ChartDataContext.prototype.originalActivityId = function() {
      return this.similarActivities.activityId;
    };

    ChartDataContext.prototype.fastestActivityId = function() {
      return this.similarActivities.efforts.fastest().get('activity_id');
    };

    ChartDataContext.prototype.effortCount = function() {
      return this.similarActivities.summary.get('effort_count');
    };

    ChartDataContext.prototype.averageValue = function() {
      return this.dimensionContext.getDimensionValue(this.similarActivities.summary.get('average_speed'));
    };

    ChartDataContext.prototype.minRangeValue = function() {
      return this.dimensionContext.getDimensionValue(this.similarActivities.summary.get('min_average_speed'));
    };

    ChartDataContext.prototype.maxRangeValue = function() {
      return this.dimensionContext.getDimensionValue(this.similarActivities.summary.get('max_average_speed'));
    };

    ChartDataContext.prototype.invertedIdx = function(idx) {
      return this.effortCount() - 1 - idx;
    };

    ChartDataContext.prototype.effortIdx = function(activityId) {
      if (activityId == null) {
        activityId = this.similarActivities.activityId;
      }
      return this.invertedIdx(this.similarActivities.efforts.effortIdx(activityId));
    };

    ChartDataContext.prototype.effortAt = function(chartIdx) {
      return this.similarActivities.efforts.at(this.invertedIdx(chartIdx));
    };

    ChartDataContext.prototype.effortDateAt = function(chartIdx) {
      return this.effortAt(chartIdx).get('start_date_local');
    };

    ChartDataContext.prototype.effortValueAt = function(chartIdx) {
      return this.dimensionContext.getDimensionValue(this.effortAt(chartIdx).get('average_speed'));
    };

    ChartDataContext.prototype.activityIdAt = function(chartIdx) {
      return this.effortAt(chartIdx).get('activity_id');
    };

    ChartDataContext.prototype.trendPoints = function() {
      return this.similarActivities.efforts.map((function(_this) {
        return function(effort, idx) {
          return {
            x: _this.invertedIdx(idx),
            y: _this.dimensionContext.getDimensionValue(effort.get('trend_speed'))
          };
        };
      })(this));
    };

    ChartDataContext.prototype.effortPoints = function() {
      return this.similarActivities.efforts.map((function(_this) {
        return function(effort, idx) {
          return {
            x: _this.invertedIdx(idx),
            y: _this.dimensionContext.getDimensionValue(effort.get('average_speed')),
            id: effort.get('activity_id')
          };
        };
      })(this));
    };

    ChartDataContext.prototype.effortForActivityId = function(activityId) {
      var difference, effort, isFaster, offset, sign;
      effort = this.similarActivities.efforts.forActivityId(activityId);
      offset = this.dimensionContext.getOffset(effort.get('average_speed'), this.similarActivities.summary.get('average_speed'));
      isFaster = this.dimensionContext.isFaster(effort.get('average_speed'), this.similarActivities.summary.get('average_speed'));
      sign = this.dimensionContext.isYAxisInverted() ? isFaster ? '+' : '-' : isFaster ? '-' : '+';
      difference = sign + this.dimensionContext.formatDimension(Math.abs(offset));
      return {
        name: effort.get('activity_name'),
        dimension: this.dimensionContext.formatDimension(effort.get('average_speed')),
        difference: Strava.Util.StringUtils.lpad(difference, 8),
        isFaster: isFaster
      };
    };

    return ChartDataContext;

  })();

}).call(this);
(function() {
  Strava.module('Strava.Labs.Activities.SimilarActivities');

  Strava.Labs.Activities.SimilarActivities.DimensionContext = (function() {
    function DimensionContext(activity) {
      this.activity = activity;
      this.dimension = this.dimension();
      this.timespanFormatter = this.timespanFormatter();
      this.dateFormatter = this.dateFormatter();
      this.dimensionFormatter = this.dimensionFormatter();
      this.chartLabelFormatter = this.chartLabelFormatter();
    }

    DimensionContext.prototype.isYAxisInverted = function() {
      return this.dimension === 'speed';
    };

    DimensionContext.prototype.getDimensionValue = function(value) {
      return this.dimensionFormatter.convert(value);
    };

    DimensionContext.prototype.formatDimension = function(value) {
      return this.dimensionFormatter.formatShort(value);
    };

    DimensionContext.prototype.formatRelativeEffort = function(value) {
      if (value) {
        return value;
      } else {
        return "\u2014";
      }
    };

    DimensionContext.prototype.formatDate = function(value, options) {
      return this.dateFormatter.format(value, options);
    };

    DimensionContext.prototype.formatDateUTC = function(value, options) {
      return this.dateFormatter.formatUTC(value, options);
    };

    DimensionContext.prototype.formatTimespan = function(value) {
      return this.timespanFormatter.display(value);
    };

    DimensionContext.prototype.formatLabel = function(value) {
      return this.chartLabelFormatter.formatShort(value);
    };

    DimensionContext.prototype.getOffset = function(speed1, speed2) {
      switch (this.dimension) {
        case 'speed':
          return speed1 - speed2;
        default:
          return 1.0 / ((1.0 / speed1) - (1.0 / speed2));
      }
    };

    DimensionContext.prototype.isFaster = function(speed1, speed2) {
      return speed1 > speed2;
    };

    DimensionContext.prototype.timespanFormatter = function() {
      return new Strava.I18n.TimespanFormatter();
    };

    DimensionContext.prototype.dateFormatter = function() {
      return new Strava.I18n.DateTimeFormatter();
    };

    DimensionContext.prototype.dimensionFormatter = function() {
      switch (this.dimension) {
        case 'pace':
          return new Strava.I18n.PaceFormatter();
        case 'swimPace':
          return new Strava.I18n.SwimPaceFormatter();
        default:
          return new Strava.I18n.DistancePerTimeFormatter();
      }
    };

    DimensionContext.prototype.chartLabelFormatter = function() {
      switch (this.dimension) {
        case 'speed':
          return new Strava.I18n.ChartLabelDistancePerTimeFormatter();
        case 'swimPace':
          return new Strava.I18n.ChartLabelSwimPaceFormatter();
        default:
          return new Strava.I18n.ChartLabelPaceFormatter();
      }
    };

    DimensionContext.prototype.dimension = function() {
      switch (this.activity.detailedType()) {
        case 'Run':
        case 'VirtualRun':
        case 'Wheelchair':
          return 'pace';
        case 'Swim':
          return 'swimPace';
        default:
          return 'speed';
      }
    };

    DimensionContext.prototype.chartLabels = function(key) {
      var ref;
      switch (key) {
        case 'allTimeAverage':
          return Strava.I18n.Locale.t('strava.labs.activities.similar_activities.chart.all_time_average');
        case 'fastestEffort':
          return Strava.I18n.Locale.t('strava.labs.activities.similar_activities.chart.fastest_effort');
        case 'dimension':
          if ((ref = this.dimension) === 'pace' || ref === 'swimPace') {
            return Strava.I18n.Locale.t('strava.labs.activities.similar_activities.chart.dimension.pace');
          } else {
            return Strava.I18n.Locale.t('strava.labs.activities.similar_activities.chart.dimension.speed');
          }
          break;
        case 'slowestEffort':
          return Strava.I18n.Locale.t('strava.labs.activities.similar_activities.chart.slowest_effort');
        case 'thisActivity':
          switch (this.activity.detailedType()) {
            case 'Ride':
            case 'EBikeRide':
            case 'VirtualRide':
            case 'Velomobile':
              return Strava.I18n.Locale.t('strava.labs.activities.similar_activities.chart.this_activity.ride');
            case 'Run':
            case 'VirtualRun':
              return Strava.I18n.Locale.t('strava.labs.activities.similar_activities.chart.this_activity.run');
            case 'Swim':
              return Strava.I18n.Locale.t('strava.labs.activities.similar_activities.chart.this_activity.swim');
            default:
              return Strava.I18n.Locale.t('strava.labs.activities.similar_activities.chart.this_activity.activity');
          }
      }
    };

    DimensionContext.prototype.activityTypeKey = function() {
      switch (this.activity.detailedType()) {
        case 'Run':
        case 'VirtualRun':
          return 'run';
        case 'Swim':
          return 'swim';
        case 'Ride':
        case 'EBikeRide':
        case 'VirtualRide':
        case 'Velomobile':
          return 'ride';
        default:
          return 'activity';
      }
    };

    return DimensionContext;

  })();

}).call(this);
(function() {
  var extend = function(child, parent) { for (var key in parent) { if (hasProp.call(parent, key)) child[key] = parent[key]; } function ctor() { this.constructor = child; } ctor.prototype = parent.prototype; child.prototype = new ctor(); child.__super__ = parent.prototype; return child; },
