(function() {
  Strava.module('Strava.Activities.Ui');

  Strava.Activities.Ui = {
    initialize: function(options) {
      if (this.isInitialized) {
        return;
      }
      this.expandDescription = !!options.expandDescription;
      this.ownerAthlete = options.ownerAthlete;
      this.prepareSlideMenu();
      this.prepareCollapsingPanels();
      this.prepareActivityHeading();
      this.prepareViewResultsButton();
      this.prepareMoreStats();
      Strava.Ui.Global.prepareAutoresizingTextbox();
      if (options && options.editableActivity) {
        this.prepareRefreshAchievementsBox(options.editableActivity);
      }
      if (Modernizr.localstorage && localStorage.getItem('activity_more_stats') === '1') {
        this.toggleMoreStats();
      }
      return this.isInitialized = true;
    },
    prepareCollapsingPanels: function() {
      return jQuery('a.collapse').off('click').on('click', function() {
        var el;
        el = jQuery(this);
        return el.closest('section').toggleClass('collapsed').find('.collapsable').slideToggle(300);
      });
    },
    prepareActivityHeading: function() {
      var description, descriptionButton, fullHeightDescription, fullHeightPrivateNote, initialHeightDescription, initialHeightPrivateNote, privateNote, privateNoteButton, section;
      section = jQuery('#heading');
      descriptionButton = section.find('.toggle-more-description');
      description = section.find('div.activity-description-js');
      fullHeightDescription = description.find('div.content').height();
      initialHeightDescription = description.height();
      this.toggleDescription = true;
      descriptionButton.on('click', (function(_this) {
        return function() {
          _this.toggleExpansion(descriptionButton, _this.toggleDescription, description, fullHeightDescription, initialHeightDescription);
          return _this.toggleDescription = !_this.toggleDescription;
        };
      })(this));
      if (fullHeightDescription > 41) {
        description.addClass('description-overflow');
        descriptionButton.fadeIn(100);
        if (this.expandDescription) {
          descriptionButton.click();
        }
      }
      if (this.ownerAthlete) {
        privateNoteButton = section.find('.toggle-more-private-note');
        privateNote = section.find('div.private-note-js');
        fullHeightPrivateNote = privateNote.find('div.content').height();
        initialHeightPrivateNote = privateNote.height();
        this.togglePrivateNote = true;
        privateNoteButton.on('click', (function(_this) {
          return function() {
            _this.toggleExpansion(privateNoteButton, _this.togglePrivateNote, privateNote, fullHeightPrivateNote, initialHeightPrivateNote);
            return _this.togglePrivateNote = !_this.togglePrivateNote;
          };
        })(this));
        if (fullHeightPrivateNote > 41) {
          return privateNoteButton.fadeIn(100);
        }
      }
    },
    toggleExpansion: function(button, toggle, element, fullHeight, initialHeight) {
      if (toggle) {
        element.addClass('expanded').height(fullHeight);
        return button.attr('title', Strava.I18n.Locale.t('strava.activities.ui.view_less'));
      } else {
        element.removeClass('expanded').height(initialHeight);
        return button.attr('title', Strava.I18n.Locale.t('strava.activities.ui.view_more'));
      }
    },
    prepareSlideMenu: function() {
      var navHeight, popupMenuHeight, slideMenu;
      slideMenu = jQuery('.slide-menu');
      navHeight = jQuery('.sidenav').height() || 0;
      popupMenuHeight = slideMenu.find('.options').height();
      if (navHeight > popupMenuHeight) {
        return slideMenu.addClass('align-bottom');
      } else {
        return slideMenu.addClass('align-top');
      }
    },
    prepareViewResultsButton: function() {
      return jQuery('.js-view-all-results').on('click', function(e) {
        var elevation, target;
        target = jQuery(e.currentTarget).attr('href');
        elevation = jQuery('#elevation-profile').outerHeight();
        jQuery('html, body').animate({
          scrollTop: jQuery(target).offset().top - elevation
        }, 600);
        return false;
      });
    },
    prepareMoreStats: function() {
      return jQuery('.show-more-js').on('click', (function(_this) {
        return function(e) {
          _this.toggleMoreStats();
          if (Modernizr.localstorage) {
            return localStorage.setItem('activity_more_stats', jQuery('.show-more-block-js:visible').length);
          }
        };
      })(this));
    },
    toggleMoreStats: function() {
      jQuery('.show-more-block-js').toggle();
      return jQuery('.show-more-js').toggle();
    },
    prepareRefreshAchievementsBox: function(editableActivity) {
      return jQuery('#refresh-achievements').on('click', function(e) {
        e.preventDefault();
        return Strava.Labs.Activities.RefreshAchievements.show({
          activityId: editableActivity.id
        }, 'div.app-icon.icon-nav-more');
      });
    }
  };

}).call(this);
