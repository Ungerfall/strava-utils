(function() {
  Strava.module('Strava.Util');

  Strava.Util.EventLogging = (function() {
    function EventLogging(host, key, athleteId) {
      this.host = host;
      this.athleteId = athleteId;
      this.key = key;
    }

    EventLogging.stmSource = null;

    EventLogging.trackingSource = function(source) {
      return this.stmSource = source;
    };

    EventLogging.createInstance = function(host, key, athleteId) {
      if (!this.instance) {
        return this.instance = new Strava.Util.EventLogging(host, key, athleteId);
      }
    };

    EventLogging.trackEvent = function(eventId, details, timestamp) {
      var args, data;
      if (timestamp == null) {
        timestamp = null;
      }
      args = {
        event: eventId,
        details: details
      };
      if (this.instance.athleteId) {
        args['athlete_id'] = this.instance.athleteId;
      }
      if (timestamp) {
        args['timestamp'] = timestamp;
      }
      data = {
        key: this.instance.key,
        data: btoa(JSON.stringify(args)).replace(/\+/g, '-').replace(/\//g, '_')
      };
      if (this.stmSource) {
        data.stm_source = this.stmSource;
      }
      return jQuery.ajax({
        url: this.instance.host + "/logging/v1/log",
        type: 'POST',
        crossDomain: true,
        contentType: 'application/x-www-form-urlencoded',
        data: data
      });
    };

    EventLogging.log = function(params) {
      params.key = this.instance.key;
      return jQuery.ajax({
        url: this.instance.host + "/logging/v2/log",
        type: 'POST',
        crossDomain: true,
        contentType: 'application/x-www-form-urlencoded',
        data: params
      });
    };

    return EventLogging;

  })();

