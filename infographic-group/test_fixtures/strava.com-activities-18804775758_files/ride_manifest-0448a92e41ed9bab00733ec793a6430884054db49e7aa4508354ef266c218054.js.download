    ChartHelper.colorGradient = function(hexcolor, bin, numbins, threshold) {
      var b, g, p, r;
      if (threshold == null) {
        threshold = [0.1, 0.7];
      }
      if (hexcolor.length === 7) {
        hexcolor = hexcolor.substr(0, 7);
      }
      r = parseInt(hexcolor.substr(0, 2), 16);
      g = parseInt(hexcolor.substr(2, 2), 16);
