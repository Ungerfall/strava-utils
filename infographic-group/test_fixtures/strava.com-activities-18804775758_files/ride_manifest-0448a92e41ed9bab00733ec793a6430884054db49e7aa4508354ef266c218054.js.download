        p = (p - 0.5) * (1 - (1 - threshold[1]) * 2) + 0.5;
        p = (1 - p) * 2;
        r = Math.round(r * p);
        g = Math.round(g * p);
        b = Math.round(b * p);
      }
      return 'rgb(' + r + ', ' + g + ', ' + b + ')';
    };

    ChartHelper.formatTimeSummary = function(x) {
      if (x <= 0) {
        return '0';
      } else if (x < 60) {
        return x + ' sec';
      } else if (x % 3600 === 0) {
        return (x / 3600) + ' hr';
      } else {
        return (Math.round(x / 6, 1) / 10) + ' min';
      }
    };

    ChartHelper.cpId2Time = function(x) {
      x = Math.round(x);
      if (x < 300) {
        return x + 1;
      } else if (x < 600) {
        return 305 + (x - 300) * 5;
      } else if (x < 900) {
        return 1830 + (x - 600) * 30;
      } else if (x < 1200) {
        return 11100 + (x - 900) * 300;
      }
    };

    ChartHelper.cpTime2Id = function(x) {
      x = Math.floor(x.toFixed(5));
      if (x <= 0) {
        return 0;
      } else if (x < 300) {
        return x - 1;
      } else if (x < 1800) {
        return 299 + Math.floor((x - 300) / 5);
      } else if (x < 10800) {
        return 599 + Math.floor((x - 1800) / 30);
      } else {
        return 899 + Math.floor((x - 10800) / 300);
      }
    };

