        if (!this.page().pageContext().isUpsell('power_zone_distribution')) {
          view = new Strava.Activities.PowerPanel.PowerZoneView({
            el: '.power-zones-chart table',
            model: this.page().powerController(),
            template: '#power-zone-template',
            powerZones: this.page().power()['zones'],
