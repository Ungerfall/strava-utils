      this.verifiedSegmentBadgePath = tableViewModel.verifiedSegmentBadgePath;
      this.rowViewModels = [];
      this.template = this.activity.isRun() ? 'activities/segments/table_run' : this.activity.isSwim() ? 'activities/segments/table_swim' : this.activity.isRide() ? 'activities/segments/table_ride' : 'activities/segments/table_other';
