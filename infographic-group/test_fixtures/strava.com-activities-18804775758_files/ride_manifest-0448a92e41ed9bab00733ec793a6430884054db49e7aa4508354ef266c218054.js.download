(function() {
  Strava.module('Strava.Labs.Activities');

  Strava.Labs.Activities.SegmentLeaderboardViewModel = (function() {
    function SegmentLeaderboardViewModel(leaderboard) {
      this.leaderboard = leaderboard;
      this.activityAthlete = null;
      this.currentAthlete = null;
      this.segmentTrackingProperties = null;
      this.isPremium = null;
      this.hasGoalsAccess = null;
      this.activityAthleteTime = null;
      this.athleteTime = null;
      this.segmentLeaderboardUpsellImagePath = null;
    }

    SegmentLeaderboardViewModel.prototype.getTopResults = function() {
      return this.leaderboard.get('top_results');
    };

    SegmentLeaderboardViewModel.prototype.getViewerContext = function() {
      return this.leaderboard.get('viewer_context');
    };

    SegmentLeaderboardViewModel.prototype.highlightRow = function(effort) {
      return this.leaderboard.get('filter') !== 'my_results' && this.currentAthlete.id === effort.athlete_id;
    };

    SegmentLeaderboardViewModel.prototype.myResults = function() {
      return this.leaderboard.get('filter') === 'my_results';
    };

    SegmentLeaderboardViewModel.prototype.filterSelector = function() {
      var dataFilter, filter, gender, selector;
      filter = this.leaderboard.get('filter');
      dataFilter = filter === 'overall' ? (gender = this.leaderboard.get('gender'), gender === 'F' ? 'women' : gender === 'M' ? 'men' : 'overall') : filter ? filter : 'overall';
      selector = "[data-filter=" + dataFilter + "]";
      if (filter === 'club') {
        selector += "[data-club-id=" + (this.leaderboard.get('club_id')) + "]";
      } else if (filter === 'age_group') {
        selector += "[data-age-group=" + (this.leaderboard.get('age_group')) + "]";
      } else if (filter === 'weight_class') {
        selector += "[data-weight-class=" + (this.leaderboard.get('weight_class')) + "]";
      }
      return selector;
    };

    SegmentLeaderboardViewModel.prototype.summarize = function() {
      return {
        segmentId: this.leaderboard.id,
        currentAthlete: this.currentAthlete.attributes,
        activityAthlete: this.activityAthlete.attributes,
        segmentTrackingProperties: this.segmentTrackingProperties,
        activityAthleteRank: this.leaderboard.get('activity_athlete_rank'),
        activityAthleteTime: this.activityAthleteTime,
        viewerRank: this.leaderboard.get('viewer_rank'),
        viewerTime: this.athleteTime,
        count: this.leaderboard.get('top_results_count'),
        clubs: this.leaderboard.get('viewer_clubs'),
        premium: this.isPremium,
        fullLeaderboardPath: this.leaderboard.fullLeaderboardPath(),
        segmentLeaderboardUpsellImagePath: this.segmentLeaderboardUpsellImagePath
      };
    };

    return SegmentLeaderboardViewModel;

  })();

