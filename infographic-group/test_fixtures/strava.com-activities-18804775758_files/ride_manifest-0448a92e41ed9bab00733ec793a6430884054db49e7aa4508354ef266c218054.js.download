      props = {
        activity_id: this.pageView.activityId(),
        activity_athlete_id: this.pageView.activityAthlete().id,
        activity_type: this.pageView.activityType(),
        segment_id: this.viewModel.model.get('segment_id'),
        segment_effort_id: this.viewModel.model.get('id'),
        entry_type: this.viewModel.model.get('entry_type'),
        effort_rank: this.viewModel.model.get('effort_rank')
      };
      if (data.hasOwnProperty('athleteId')) {
        props['target_athlete_id'] = data.athleteId;
      }
      return props;
    };

    SegmentEffortDetailView.prototype.trackClick = function(event) {
      var data;
      data = this.$(event.target).closest('.track-click').data();
      Strava.ExternalAnalytics.trackV2({
        category: 'activity_detail',
        page: 'segment_effort',
        action: 'click',
        element: data.trackingElement,
        properties: this.trackingProperties(data)
      });
      return this.trackAction('screen_exit');
    };

    SegmentEffortDetailView.prototype.trackAction = function(action) {
      return Strava.ExternalAnalytics.trackV2({
        category: 'activity_detail',
        page: 'segment_effort',
        action: action,
        properties: this.trackingProperties({})
      });
    };

