      for (i = 0, len = efforts.length; i < len; i++) {
        currentEffort = efforts[i];
        added = false;
        for (j = 0, len1 = levels.length; j < len1; j++) {
          level = levels[j];
          overlap = false;
          for (k = 0, len2 = level.length; k < len2; k++) {
            effort = level[k];
            if (currentEffort.id === effort.id) {
              continue;
            }
            cStart = parseInt(currentEffort.get('start_index'));
            cEnd = parseInt(currentEffort.get('end_index'));
            eStart = parseInt(effort.get('start_index'));
            eEnd = parseInt(effort.get('end_index'));
            if ((eStart <= cStart && cStart <= eEnd) || (eStart <= cEnd && cEnd <= eEnd) || (cStart <= eStart && eEnd <= cEnd)) {
              overlap = true;
              break;
            }
          }
          if (!overlap) {
            level.push(currentEffort);
            added = true;
            break;
          }
        }
        if (!added) {
          levels.push([currentEffort]);
        }
      }
      return levels;
    };

    return SegmentLevels;

  })();

