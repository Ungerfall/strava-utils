    SegmentEffortDetailView.prototype.viewAnalysis = function(event) {
      var currentTarget, end, start;
      currentTarget = this.$(event.currentTarget);
      if (currentAthlete.isSegmentsRestricted()) {
        this.pageView.router().changeMenuTo('analysis', true);
      } else if (currentTarget.data('segment-effort-id')) {
        this.pageView.pageContext().segmentEffortId(currentTarget.data('segment-effort-id'));
        this.pageView.router().changeMenuTo('analysis', true);
      } else {
        start = currentTarget.data('start-id');
        end = currentTarget.data('end-id');
        this.pageView.router().changeMenuTo("analysis/" + start + "/" + end, true);
      }
      return event.preventDefault();
    };

    SegmentEffortDetailView.prototype.renderDetails = function() {
      var raceShapeHref, segmentEffort, upsellTrainingPlan;
      segmentEffort = this.viewModel.summarize();
      raceShapeHref = window.btoa ? "/segments/" + segmentEffort.segment_id + "/compare/" + (window.btoa(segmentEffort.id)) : 'https://support.strava.com/hc/en-us/articles/216917447';
      upsellTrainingPlan = this.pageView.canSeeTrainingPlans() && !this.pageView.hasTrainingPlan() && this.pageView.activityAthlete().get('id') === this.pageView.currentAthlete().get('id');
      this.renderTemplate({
        segmentEffort: segmentEffort,
        hidden: this.viewModel.initiallyHidden,
        athlete: this.pageView.activityAthlete().toJSON(),
        currentAthlete: this.pageView.currentAthlete().toJSON(),
        raceShapeHref: raceShapeHref,
        upsellTrainingPlan: upsellTrainingPlan
      });
      if (this.viewModel.isPR()) {
        return this.$('.pr-1').show();
      } else {
        return this.$('.pr').show();
      }
    };

    SegmentEffortDetailView.prototype.renderStats = function() {
      return this.$('.effort-details table').html(this.getTemplateFor(this.stats_template)({
        segmentEffort: this.viewModel.summarize(),
        showStats: this.pageView.showStats(),
        supportsGap: this.pageView.supportsGap()
      }));
    };

    SegmentEffortDetailView.prototype.renderChart = function() {
      var $chartCanvas, chartView, converted;
      converted = this.viewModel.convertedIndices();
      $chartCanvas = this.$('.effort-elevation-profile');
      chartView = new Strava.Labs.Activities.SegmentEffortChartView(this.pageView.chartContext(), this.pageView.streamsRequest);
      chartView.showSegment(converted[0], converted[1]);
      return $chartCanvas.html(chartView.render().el);
    };

    SegmentEffortDetailView.prototype.handleSegmentEffortDetailRendered = function() {
      return this.trigger('segmentEffortDetailRendered', this);
    };

    SegmentEffortDetailView.prototype.close = function() {
      return this.trigger('segmentEffortDetailClosed', this.viewModel.model.id);
    };

    SegmentEffortDetailView.prototype.clear = function() {
      if (this.goalUpsell != null) {
        this.goalUpsell.dismissTooltip();
      }
      return this.$el.empty();
    };

    SegmentEffortDetailView.prototype.setGoal = function(event) {
      var ctaID;
      if (this.pageView.hasGoalsAccess()) {
        Strava.ExternalAnalytics.trackV2({
          category: 'goals',
          page: 'activity_detail',
          action: 'click',
          element: 'set_goal'
        });
        return Strava.PerformanceGoals.Create.View.show(new Strava.PerformanceGoals.SegmentGoal(this.viewModel.goalDetail()), this.goalsController);
      } else {
        this.goalUpsell.render({}, event.currentTarget);
        Strava.ExternalAnalytics.trackV2({
          category: 'summit_upsell',
          page: 'activity_detail',
          action: 'screen_enter',
          element: 'join_summit_set_goal'
        });
        ctaID = '.content a';
        return jQuery('#js-snw-performance-goals-upsell').off('click', ctaID).on('click', ctaID, function() {
          return Strava.ExternalAnalytics.trackV2({
            category: 'summit_upsell',
            page: 'activity_detail',
            action: 'click',
            element: 'join_summit_set_goal'
          });
        });
      }
    };

    SegmentEffortDetailView.prototype.trackingProperties = function(data) {
