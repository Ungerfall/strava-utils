          view.render();
          this.page().powerController().deferred.done((function(_this) {
            return function() {
              return _this.$$('div.power-loader').remove();
            };
          })(this));
        }
      }
      this.addPowerHeaderView($target);
      this.addLogging($target, 'join_summit_power_distribution');
      this.page().collapseHeader();
      return view;
    },
    createZoneDistributionView: function() {
